# PixelGuard — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# Gemini API key (for AI violation analysis)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Cloud Vision API key
# Get from: https://console.cloud.google.com → APIs → Cloud Vision API → Credentials
VISION_API_KEY=your_vision_api_key_here

# Google Custom Search API key + Search Engine ID
# API key: https://console.cloud.google.com → APIs → Custom Search API → Credentials
# CX (Search Engine ID): https://programmablesearchengine.google.com → Create → enable "Search entire web"
CUSTOM_SEARCH_API_KEY=your_custom_search_key_here
CUSTOM_SEARCH_CX=your_search_engine_id_here

# Firebase service account credentials (paste entire JSON as one line)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then run: cat serviceAccountKey.json | python -c "import json,sys; print(json.dumps(json.load(sys.stdin)))"
FIREBASE_CREDS_JSON={"type":"service_account","project_id":"..."}
